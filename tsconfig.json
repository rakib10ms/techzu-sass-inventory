{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",             /* NodeNext এর বদলে ESNext */
    "moduleResolution": "bundler",  /* ক্লিন ইমপোর্টের জন্য এটি ম্যাজিকের মতো কাজ করবে */
    "allowImportingTsExtensions": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}