model Company {
  id    Int     @id @default(autoincrement())
  name  String?
  email String  @unique

  // এই লাইনগুলো নিশ্চিত করুন
  outlets    Outlet[]
  users      User[] // <--- এই লাইনটি অবশ্যই যোগ করতে হবে
  products   Product[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("companies")
}
